{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM"],
    "types": ["node"],
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "platform/*": ["./assets/platform/*"]
    }
  },
  "include": ["tests/**/*.ts", "assets/platform/sdk/**/*.ts"]
}
